
@{
    ViewBag.Title = "Changepassword";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<form method="post">
    <div class="container-fluid">
        <div class="row py-2">
            <div class="col-sm-12">
                <p class="fs-3 text-center"> Welcome to Change   <b class="text-mycolor"> Password Page</b></p>
                <hr class="mx-auto w-30" />

            </div>
            <!--Application start-->

            <div class="col-sm-4 mt-3 shadow p-3 mb-5 bg-white rounded mx-auto">
                <h4 class="text-center">Change<b class="text-mycolor"> Password</b></h4>
                <div class="form-floating mb-3">
                    <input type="text" name="opass" class="form-control" id="opass" placeholder="name@example.com">
                    <label for="opass">Old Password</label>
                </div>
                <div class="form-floating mb-3">
                    <input type="text" name="npass" class="form-control" id="npass" placeholder="name@example.com">
                    <label for="npass">New Password</label>
                </div>
                <div class="form-floating mb-3">
                    <input type="text" name="cpass" class="form-control" id="cpass" placeholder="name@example.com">
                    <label for="conpass">Confirm Password</label>
                </div>
                <input type="submit" value="Change Password" class=" btn btn-success" />
            </div>
        </div>
     </div>
</form>