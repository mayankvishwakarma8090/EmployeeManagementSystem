
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_GeneralLayout.cshtml";
}

<div class="container-fluid">
    <!--start slider-->
    <div class="row slider">
        <div class="col-sm-12 p-0">
            <div id="carouselExample" class="carousel slide">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="~/Content/images/1.jpg" class="d-block w-100 img-fluid sliderimg" alt="...">
                    </div>
                    <div class="carousel-item">
                        <img src="~/Content/images/2.jpg" class="d-block w-100 img-fluid sliderimg" alt="...">
                    </div>
                    <div class="carousel-item">
                        <img src="~/Content/images/3.jpg" class="d-block w-100 img-fluid sliderimg" alt="...">
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    </div>
    <!--End slider-->
    <!--Start about-->
    <div class="row py-5" style="background:#ff6a000e;text-align:justify;">
        <div class="col-sm-10 mx-auto">
            <div class="row py-3">
                <p class="fs-3 text-center">
                    About<b class="text-mycolor"> Us  </b><br />
                    <span class="fs-5">All Information About HireNext</span>
                    <hr class="w-25 mx-auto" />
                </p>
                <div class="col-sm-6 p-2">


                    <p>
                        At HireNext, we believe that a workplace should be more than just a place to earn a living — it should be a space where people grow, collaborate, and create meaningful impact. Since our inception, we have been committed to building a team-driven environment where talent meets opportunity and where every individual’s contribution truly matters.
                        We specialize in connecting skilled professionals with the right opportunities, ensuring that both companies and candidates achieve their fullest potential. From job placement and career counseling to employee training and development, our focus is on making professional growth a reality for everyone we serve.
                        Our mission is simple: to empower people and businesses to succeed together. We understand that hiring the right people is the foundation of any organization’s success. That’s why we go beyond resumes and job descriptions — we focus on cultural fit, skill development, and long-term growth.
                        For job seekers, we offer more than just a list of vacancies. We provide mentorship, resume building assistance, interview preparation, and career pathway guidance. Whether you are starting your first job or making a career transition, our team is dedicated to helping you take the right steps with confidence.
                    </p>
                    <p>Hello, My name is MAYANK and I am from P.</p>
                    <a class="btn btn-danger">Read More</a>
                </div>
                <div class="col-sm-6 px-4 py-2">
                    <img src="~/Content/images/pexels-rdne-7580709.jpg" class="img-thumbnail" />
                </div>
            </div>
        </div>
    </div>
    <!--End about-->
    <!--Start Services-->
    <div class="row py-5">
        @* start heading *@
        <p class="fs-3 text-center">
            Our<b class="text-mycolor"> Services  </b><br />
            <span class="fs-5">Simplifying HR with Modern Solution</span>
            <hr class="w-25 mx-auto" />
        </p>
        @* End Heading *@

        <div class="col-sm-10 mx-auto">
            <div class="row py-3">
                <div class="col-sm-3 ">
                    <div class="card mx-auto shadow-lg p-2 servicescard border border-0">
                        <img src="~/Content/images/1.jpg" class="card-img-top img-fluid servicesimg" alt="...">
                        <div class="card-body">
                            <h5 class="card-title">
                                Workforce Analytics & Reporting
                            </h5>
                            <p class="card-text">Real-time dashboards and custom reports help HR analyze performance, track trends, and make informed workforce decisions efficiently.</p>
                            <a href="#" class="btn btn-danger">Know more</a>
                        </div>
                    </div>
                </div>
                <div class="col-sm-3 ">
                    <div class="card mx-auto shadow-lg p-2 servicescard border border-0">
                        <img src="~/Content/images/service3.jpg" class="card-img-top img-fluid servicesimg" alt="...">
                        <div class="card-body">
                            <h5 class="card-title">
                                Recruitment & Onboarding Automation
                            </h5>
                            <p class="card-text">
                                Automates hiring processes like resume screening, interview scheduling, offer letters, and employee onboarding for faster, paperless recruitment.
                            </p>
                            <a href="#" class="btn btn-danger">Know more</a>
                        </div>
                    </div>
                </div>
                <div class="col-sm-3 ">
                    <div class="card mx-auto shadow-lg p-2 servicescard border border-0">
                        <img src="~/Content/images/service4.jpg" class="card-img-top img-fluid servicesimg" alt="...">
                        <div class="card-body">
                            <h5 class="card-title">Responsive Website</h5>
                            <p class="card-text">
                                Our websites are designed to look on any device — desktop,tablet,ormobile. With adaptive layouts and optimized speed,your visitors enjoy a seamless browsing experience every time.
                            </p>
                            <a href="#" class="btn btn-danger">Know more</a>
                        </div>
                    </div>
                </div>
                <div class="col-sm-3 ">
                    <div class="card mx-auto shadow-lg p-2 servicescard border border-0">
                        <img src="~/Content/images/service2.jpg" class="card-img-top img-fluid servicesimg" alt="...">
                        <div class="card-body">
                            <h5 class="card-title">
                                Task & Project Assignment System
                            </h5>
                            <p class="card-text">
                                
                                Assign tasks based on roles, track deadlines, and boost productivity using visual boards like Kanban or Gantt charts.
                            </p>
                            <a href="#" class="btn btn-danger">Know more</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--end Services-->
    <!--facts Start-->
    <div class="row py-5 fact" style="background:#ff6a000e;text-align:justify;">
        @* start heading *@
        <p class="fs-3 text-center">
            Top<b class="text-mycolor"> Facts  </b><br />
            <span class="fs-5">Smart Matrics ,Real-Time Results</span>
            <hr class="w-25 mx-auto" />
        </p>
        @* End Heading *@
        <div class="col-sm-10 mx-auto">
            <div class="row py-3">
                <div class="col-sm-4">
                    <div class="mx-auto factic"><i class="fa-solid fa-book-open "></i></div>
                    <h3 class="text-center mt-2">1000+</h3>
                    <p class="text-center">
                        Successful Job Placements – We’ve helped thousands of professionals find their ideal career opportunities.

                    </p>
                </div>
                <div class="col-sm-4">
                    <div class="mx-auto factic"><i class="fa-solid fa-book-open "></i></div>
                    <h3 class="text-center mt-2">300+</h3>
                    <p class="text-center">
                        Trusted Corporate Clients – Our recruitment solutions power the growth of companies across multiple industries.
                    </p>
                </div>
                <div class="col-sm-4">
                    <div class="mx-auto factic"><i class="fa-solid fa-book-open "></i></div>
                    <h3 class="text-center mt-2">24/7</h3>
                    <p class="text-center">
                        Support & Guidance – Always available to help you with career advice, job listings, and recruitment needs.
                    </p>
                </div>
            </div>
        </div>
    </div>
    <!--facts End-->
    <!--Gallery start-->
    <div class="row py-5 gallery" id="gallery">
        @* start heading *@
        <p class="fs-3 text-center">
            Interior<b class="text-mycolor"> Gallery</b><br />
            <span class="fs-5">Creative Interiors For Smart Teams</span>
            <hr class="w-25 mx-auto" />
        </p>
        @* End Heading *@

        <div class="col-sm-10 mx-auto">
            <div class="row py-3">
                <div class="col-sm-4 p-2">
                    <img src="~/Content/images/gallery1.jpg" class="img-thumbnail imgpic w-100" />
                </div>
                <div class="col-sm-4 p-2">
                    <img src="~/Content/images/office.jpg.jpg" class="img-thumbnail imgpic w-100" />
                </div>
                <div class="col-sm-4 p-2">
                    <img src="~/Content/images/gallery2.jpg" class="img-thumbnail imgpic w-100" />
                </div>
            </div>
            <div class="row py-3">
                <div class="col-sm-4 p-2">
                    <img src="~/Content/images/3.jpg" class="img-thumbnail imgpic w-100" />
                </div>
                <div class="col-sm-4 p-2">
                    <img src="~/Content/images/service3.jpg" class="img-thumbnail imgpic w-100" />
                </div>
                <div class="col-sm-4 p-2">
                    <img src="~/Content/images/1.jpg" class="img-thumbnail imgpic w-100" />
                </div>
            </div>
        </div>
    </div>
    <!--Gallery End-->


</div>

