
@{
    ViewBag.Title = "ResetPasswordForAdmin";
    Layout = "~/Views/Shared/_GeneralLayout.cshtml";
}

<form method="post">
    <div class="container-fluid">
        <div class="row py-5">
            <div class="col-sm-4 shadow p-3 mb-5 bg-white rounded mx-auto">
                <h4 class="text-center">Reset Admin <b class="text-mycolor">Password</b></h4>
                <div class="form-floating mb-3">
                    <input type="password" class="form-control" name="newPassword" id="floatingopass" placeholder="" required>
                    <label for="floatingnpass">New Password</label>
                </div>
                <div class="form-floating mb-3">
                    <input type="password" class="form-control" name="confirmPassword" id="floatingopass" placeholder="" required>
                    <label for="floatingcpass">Confirm New Password</label>
                </div>
                <input type="submit" class="btn btn-success" value="Change Password" />
            </div>
        </div>
    </div>
</form>

