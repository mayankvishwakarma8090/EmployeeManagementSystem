
@{
    ViewBag.Title = "ER";
    Layout = "~/Views/Shared/_GeneralLayout.cshtml";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Your Portfolio</title>
    <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Segoe UI', sans-serif;
      line-height: 1.6;
      background-color: #f9f9f9;
      color: #333;
    }

    header {
      background: #333;
      color: #fff;
      padding: 20px 40px;
      text-align: center;
    }

    nav {
      margin-top: 10px;
    }

    nav a {
      color: #fff;
      text-decoration: none;
      margin: 0 15px;
    }

    .hero {
      padding: 60px 20px;
      text-align: center;
      background: #eee;
    }

    .hero h1 {
      font-size: 2.5rem;
    }

    .hero p {
      margin-top: 10px;
      font-size: 1.1rem;
    }

    #portfolio {
      padding: 60px 20px;
      background: #fff;
    }

    #portfolio h2 {
      text-align: center;
      margin-bottom: 40px;
    }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .portfolio-item {
      background: #f4f4f4;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      transition: transform 0.3s;
    }

    .portfolio-item:hover {
      transform: scale(1.02);
    }

    .portfolio-item img {
      width: 100%;
      height: auto;
      display: block;
    }

    .portfolio-item .content {
      padding: 15px;
    }
      .hero p {
        font-size: 1rem;
      }
    }
    </style>
</head>
<body>

    <header>
        <h1>Welcome to My Website</h1>
        <nav>
            <a href="#portfolio">Portfolio</a>
            <a href="#contact">Contact</a>
        </nav>
    </header>

    <section class="hero">
        <h1>Hello, I'm [Your Name]</h1>
        <p>A passionate designer and developer. Scroll down to see my work!</p>
    </section>

    <section id="portfolio">
        <h2>My Portfolio</h2>
        <div class="portfolio-grid">
            <div class="portfolio-item">
                <img src="https://via.placeholder.com/400x250" alt="Project 1">
                <div class="content">
                    <h3>Project Title 1</h3>
                    <p>Short description of the project goes here.</p>
                </div>
            </div>

            <div class="portfolio-item">
                <img src="https://via.placeholder.com/400x250" alt="Project 2">
                <div class="content">
                    <h3>Project Title 2</h3>
                    <p>Short description of the project goes here.</p>
                </div>
            </div>

            <div class="portfolio-item">
                <img src="https://via.placeholder.com/400x250" alt="Project 3">
                <div class="content">
                    <h3>Project Title 3</h3>
                    <p>Short description of the project goes here.</p>
                </div>
            </div>

            <!-- Add more projects as needed -->
        </div>
    </section>

</body>
</html>

