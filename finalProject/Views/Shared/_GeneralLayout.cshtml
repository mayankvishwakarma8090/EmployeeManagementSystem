        }
        .factic{
            height:80px;
            width:80px;
            border:1px solid gray;
            border-radius:50%;
            font-size:40px;
            line-height:70px;
            transition:2s;
            padding:5px;
            text-align:center;
        }
        .factic:hover{
            background:#FF1744;
            color:white;
            transition:2s;
        }
            .imgpic{
                height:250px;
            }
