        .imgfeature {
            height: 100px;
        }
        .featureic {
            font-size: 10px;
            color: #ff0000 !important;
        }
        .footermenu:hover {
            transform: translateX(10px);
            color: #f4511e;
            transition:1s;
            
        }
        .userimg{
            height:120px;
            width:120px;
            border-radius:50%;
            border:1px solid black;
        }
        .ic:hover {
            transform:rotate(360deg);
            transition:.5s;
            background:#FF6D00;
            color:white;
        }
        .fhover {
            display: inline-flex;
            text-decoration: none;
            transition: .5s;
            color: #bbbbbb;
            padding-left: 3px;
        }

            .fhover:hover {
                color: #EF6C00;
                transform: translateX(5px);
                transition: .5s;
            }
       
