        }
        .text-mycolor {
            color: #FF6D00 !important;
        }
        .header{
            min-height:50px;
            padding-top:10px;
        }
        .ic {
            font-size: 20px;
            height: 30px;
            width: 30px;
            text-align: center;
            line-height: 30px;
            border: 1px solid #FF6D00;
            color: #FF6D00;
            transition: .5s;
